# ------ Database (AWS RDS Postgres) ------
# Replace <user>, <password>, <rds-endpoint>, <db-name> with your RDS values.
# Example host: mydb.abc123xyz.us-east-1.rds.amazonaws.com
# If your RDS enforces SSL, append ?ssl=require (asyncpg) / ?sslmode=require (psycopg2).
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<rds-endpoint>:5432/<db-name>?ssl=require
DATABASE_URL_SYNC=postgresql+psycopg2://<user>:<password>@<rds-endpoint>:5432/<db-name>?sslmode=require

# ------ Redis / Celery ------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ------ Retell AI ------
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_FROM_NUMBER=
RETELL_WEBHOOK_SECRET=

# ------ OpenAI ------
OPENAI_API_KEY=
EVAL_MODEL=gpt-4o-mini

# ------ Platform config ------
DEFAULT_PASS_THRESHOLD=0.7
MAX_CALLS_PER_RUN=50
MAX_COST_PER_RUN_USD=10.0
MAX_CALL_DURATION_SEC=600

# ------ App ------
LOG_LEVEL=INFO
ENVIRONMENT=development

# Comma-separated origins allowed to call SSE / CORS endpoints from the browser.
# Example: http://localhost:3000,https://intake-edge-ai.example.com
UI_CORS_ORIGINS=http://localhost:3000
